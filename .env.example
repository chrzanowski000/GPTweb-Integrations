# Path to the OAuth 2.0 Desktop App client secret JSON
# Download from Google Cloud Console → APIs & Services → Credentials → your Desktop App OAuth client
GOOGLE_CLIENT_SECRET_PATH=client_secret.json

# Path where the OAuth token (refresh token) will be stored after first login
GOOGLE_TOKEN_PATH=token.json

# Path where the spreadsheet ID is stored after first run (auto-created, do not edit)
SHEET_ID_PATH=sheet_id.txt

# Name of the Google Spreadsheet to create (used only on first run)
SPREADSHEET_NAME=GPTweb-integration-test

# Worksheet name inside the spreadsheet (auto-created if missing)
WORKSHEET_NAME=FormulaIngredients

# LM Studio local API base URL
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
