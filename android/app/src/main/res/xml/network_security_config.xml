<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP for private/Tailscale addresses -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.0.0/8</domain>
        <domain includeSubdomains="true">192.168.0.0/16</domain>
        <domain includeSubdomains="true">172.16.0.0/12</domain>
        <domain includeSubdomains="true">100.64.0.0/10</domain>
        <!-- Tailscale MagicDNS hostnames -->
        <domain includeSubdomains="true">ts.net</domain>
        <domain includeSubdomains="true">tailnet</domain>
    </domain-config>
</network-security-config>
